{
  "name": "Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens",
        "rust-lang.rust-analyzer",    // <-- Rust LSP
        "ms-python.python"            // <-- let VS Code find the conda env
      ],
      "settings": {
        "rust-analyzer.cargo.targetDir": "/workspace/target",
        "python.defaultInterpreterPath": "/opt/conda/envs/trading_env_f/bin/python",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/node/.claude,type=volume",
    "source=/home/matebarey/miniconda3/envs/trading_env_f,target=/opt/host-conda-env,type=bind"
  ],
  "remoteEnv": {
    "CONDA_PREFIX": "/opt/host-conda-env",
    "LD_LIBRARY_PATH": "/opt/host-conda-env/lib:/opt/host-conda-env/lib/python3.*/site-packages/torch/lib",
    "PYTHONPATH": "/opt/host-conda-env/lib/python3.10/site-packages",
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
}